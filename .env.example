# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Avisos do AI SDK no terminal (ex. "specificationVersion compatibility mode"). Por defeito omitidos.
# AI_SDK_LOG_WARNINGS=true

# --- Autenticação do serviço assistente (header x-assistant-key do front) ---
ASSISTANT_API_KEY=o_mesmo_segredo_do_assistente

# --- API TraceLeads (Nest) — o assistente só fala HTTP aqui; não conecta ao Postgres ---
# Opção 1 (recomendada): URL completa da API
TRACELEADS_API_URL=http://localhost:3333

# Opção 2: compor (útil se o deploy já exporta host/porta separados)
# TRACELEADS_API_PROTOCOL=http
# TRACELEADS_API_HOST=localhost
# TRACELEADS_API_PORT=3333

# --- CORS (origens do front, separadas por vírgula) ---
# CORS_ORIGINS=http://localhost:7000,https://app.seudominio.com

# --- HTTP deste serviço (recomendado; evita colidir com PORT=3000 do Nest no mesmo .env) ---
# Porta HTTP deste serviço (evita 7070 se já estiver ocupada por outro processo)
ASSISTANT_HTTP_PORT=7071
# Alternativa: PORT=7071 (só se não partilhares .env com a API Nest)

# --- Docker Swarm / Traefik (só no servidor; ver docker-compose.yml e .deploy/env.stack.example) ---
# Host público do assistente (sem https://), igual ao usado no router Traefik
# TRACELEADS_TRAEFIK_URL_ASSISTANT=assistant.traceleads.com.br
