# Copiar para .deploy/env.stack no servidor (não commitar segredos).
# Este ficheiro é carregado por ./deploy.sh se existir.

export NODE_ENV_TRACELEADS=production
export STACK_NAME=trace_leads_assistant

# Tag da imagem: latest (production) ou homolog
export NODE_ENV=production

export OPENAI_API_KEY=
export OPENAI_MODEL=gpt-4o-mini
export ASSISTANT_API_KEY=

# URL da API Nest que o assistente chama (HTTPS público ou URL interna do Swarm)
export TRACELEADS_API_URL=https://api.traceleads.com.br

# Host só do domínio, sem schema — igual a TRACELEADS_TRAEFIK_URL_API no outro stack
export TRACELEADS_TRAEFIK_URL_ASSISTANT=assistant.traceleads.com.br

# Origens CORS (vírgula). Incluir o domínio do front que usa VITE_ASSISTANT_API_URL
export CORS_ORIGINS=https://app.traceleads.com.br
